---
pagination:
  data: recipes
  size: 1
  alias: recipe
permalink: "/blog/{{ recipe.slug }}/index.html"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ recipe.name }} — рецепт | Anastasiia"
  description: "{{ recipe.name }}: {{ recipe.calories }} ккал, {{ recipe.protein }} г білка. Рецепт із колекції Анастасії Шерстюк."
---
{% include "partials/header.njk" %}

<article class="cd-post">

  <header class="cd-post-head">
    <a href="/blog/" class="cd-back-link">&#8592; Всі рецепти</a>
    <span class="cd-eyebrow-line"></span>
    <div class="cd-post-title-row">
      <h1 class="cd-post-title">{{ recipe.name }}</h1>
      <div class="cd-macros">
        {%- if recipe.protein %}<span>Білки: {{ recipe.protein }} г</span><i class="cd-macro-sep"></i>{% endif %}
        {%- if recipe.fats %}<span>Жири: {{ recipe.fats }} г</span><i class="cd-macro-sep"></i>{% endif %}
        {%- if recipe.carbs %}<span>Вуглеводи: {{ recipe.carbs }} г</span>{% endif %}
      </div>
    </div>
  </header>

  <div class="cd-post-body">
    <div class="cd-post-photos">
      <div class="cd-post-photo-main" style="background-image:url('{{ recipe.image }}');" role="img" aria-label="{{ recipe.name }}"></div>
      {#- The design lays out a main photo plus two supporting shots. The CMS
          export has only a single image per recipe (its `Images` gallery column
          is empty), so the secondary row renders only if extras ever exist. #}
      {%- if recipe.gallery and recipe.gallery | length %}
      <div class="cd-post-photo-row">
        {%- for g in recipe.gallery | limit(2) %}
        <div class="cd-post-photo-side" style="background-image:url('{{ g }}');" role="img" aria-label=""></div>
        {%- endfor %}
      </div>
      {%- endif %}
    </div>

    <div class="cd-post-card">
      <div class="cd-post-card-top">
        {%- if recipe.categoryName %}<span class="cd-tag cd-tag--light">{{ recipe.categoryName }}</span>{% endif %}
        <div class="cd-post-card-meta">
          {%- if recipe.minutes %}<span>{{ recipe.minutes }} хв на приготування</span>{% endif %}
          {%- if recipe.calories %}<strong>{{ recipe.calories }} ккал</strong>{% endif %}
        </div>
      </div>

      <h2 class="cd-post-card-title">{{ recipe.name }}</h2>
      <hr class="cd-rule">

      {%- if recipe.ingredients %}
      <section class="cd-post-section">
        <h3 class="cd-post-section-title">Інгредієнти</h3>
        <div class="cd-rich">{{ recipe.ingredients | cleanRichText | safe }}</div>
      </section>
      <hr class="cd-rule">
      {%- endif %}

      {%- if recipe.instructions %}
      <section class="cd-post-section">
        <h3 class="cd-post-section-title">Інструкція</h3>
        <div class="cd-rich">{{ recipe.instructions | cleanRichText | safe }}</div>
      </section>
      {%- endif %}
    </div>
  </div>

  {%- set others = recipes | reject("slug", recipe.slug) | limit(3) %}
  {%- if others | length %}
  <section class="cd-more">
    <h2 class="cd-section-head">Інші рецепти</h2>
    <div class="cd-recipe-grid">
      {%- for r in others %}
      <article class="cd-card">
        <div class="cd-card-img" style="background-image:url('{{ r.image }}');" role="img" aria-label="{{ r.name }}"></div>
        <div class="cd-card-body">
          <div class="cd-meta">
            {%- if r.categoryName %}<span class="cd-tag">{{ r.categoryName }}</span>{% endif %}
            {%- if r.calories %}<span class="cd-meta-kcal">{{ r.calories }} ккал</span>{% endif %}
          </div>
          <h3 class="cd-card-title">{{ r.name }}</h3>
        </div>
        <a href="/blog/{{ r.slug }}/" class="cd-btn cd-btn--outline">Дивитись рецепт</a>
      </article>
      {%- endfor %}
    </div>
  </section>
  {%- endif %}
</article>

{% include "partials/footer.njk" %}
