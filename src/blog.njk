---
layout: layouts/base.njk
permalink: /blog/index.html
title: Рецепти — Anastasiia
description: Колекція корисних і смачних рецептів від Анастасії Шерстюк.
---
{% set featured = recipes | first %}
{% set rest = recipes | after(1) %}
{% set categories = recipes | categories %}

{% include "partials/header.njk" %}

<section id="blog-content" class="cd-blog cd-reveal">

  <div class="cd-blog-intro">
    <div class="cd-eyebrow">
      <span class="cd-eyebrow-line"></span>
      <span>Рецепти</span>
    </div>
    <h1 class="cd-blog-heading">Твоя колекція корисної і смачної їжі</h1>
    <p class="cd-blog-sub">
      Рецепти, які я готую сама і рекомендую своїм клієнткам — прості, ситні та без зайвих калорій.
    </p>
  </div>

  {%- if featured %}
  <article class="cd-featured">
    <div class="cd-featured-img" style="background-image:url('{{ featured.image }}');" role="img" aria-label="{{ featured.name }}">
      {#- Desktop shows category and kcal as one pill; below 1100px the card
          collapses to the standard recipe-card layout, where the category moves
          into the body as a chip and only the kcal stays on the photo. The
          category span is dropped from the pill there rather than duplicated. #}
      {%- if featured.categoryName or featured.calories %}
      <span class="cd-featured-badge">
        {%- if featured.categoryName %}<span class="cd-featured-badge-cat">{{ featured.categoryName }}{% if featured.calories %} · {% endif %}</span>{% endif %}
        {%- if featured.calories %}{{ featured.calories }} ккал{% endif -%}
      </span>
      {%- endif %}
    </div>
    <div class="cd-featured-body">
      {%- if featured.categoryName %}<span class="cd-card-tag cd-featured-tag">{{ featured.categoryName }}</span>{% endif %}
      <div class="cd-featured-text">
        <h2 class="cd-featured-title">{{ featured.name }}</h2>
        <p class="cd-featured-desc">
          {{ featured.description or (featured.minutes ~ " хв · " ~ featured.protein ~ " г білка · " ~ featured.carbs ~ " г вуглеводів · " ~ featured.fats ~ " г жирів") }}
        </p>
      </div>
      <a href="/blog/{{ featured.slug }}/" class="cd-btn cd-btn--orange">Дивитись рецепт</a>
    </div>
  </article>
  {%- endif %}

  <div class="cd-blog-list">
    {#- The design shipped a 5-way category filter, but every real recipe is
        currently in one category. Rendering a filter with a single option would
        be theatre, so it only appears once there are genuinely 2+. #}
    {%- if categories | length > 1 %}
    <div class="cd-filters" role="group" aria-label="Фільтр за категорією">
      <button type="button" class="cd-filter is-active" data-filter="all">Всі</button>
      {%- for c in categories %}
      <button type="button" class="cd-filter" data-filter="{{ c.slug }}">{{ c.name }}</button>
      {%- endfor %}
    </div>
    {%- endif %}

    {%- if rest | length %}
    <div class="cd-recipe-grid">
      {%- for r in rest %}
      <article class="cd-card" data-category="{{ r.category }}">
        <div class="cd-card-img" style="background-image:url('{{ r.image }}');" role="img" aria-label="{{ r.name }}">
          {%- if r.calories %}<span class="cd-card-kcal">{{ r.calories }} ккал</span>{% endif %}
        </div>
        <div class="cd-card-body">
          {%- if r.categoryName %}<span class="cd-card-tag">{{ r.categoryName }}</span>{% endif %}
          <h3 class="cd-card-title">{{ r.name }}</h3>
          <a href="/blog/{{ r.slug }}/" class="cd-btn cd-btn--orange">Дивитись рецепт</a>
        </div>
      </article>
      {%- endfor %}
    </div>
    {%- endif %}
  </div>
</section>

{% include "partials/footer.njk" %}
